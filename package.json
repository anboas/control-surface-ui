{
  "name": "control-surface-ui",
  "version": "0.1.0",
  "description": "A reusable CSS and JavaScript framework for dense enterprise control surfaces, analytics tooling, review workflows, diagrams, graphs, and data-heavy workspaces.",
  "type": "module",
  "main": "./dist/interface-framework.esm.js",
  "module": "./dist/interface-framework.esm.js",
  "browser": "./dist/interface-framework.js",
  "style": "./dist/interface-framework.css",
  "unpkg": "./dist/interface-framework.min.js",
  "jsdelivr": "./dist/interface-framework.min.js",
  "releaseNotes": "./CHANGELOG.md",
  "cdn": {
    "css": "./dist/interface-framework.css",
    "cssMin": "./dist/interface-framework.min.css",
    "js": "./dist/interface-framework.js",
    "jsMin": "./dist/interface-framework.min.js",
    "esm": "./dist/interface-framework.esm.js",
    "esmMin": "./dist/interface-framework.esm.min.js"
  },
  "releaseGovernance": {
    "policy": "./docs/release-governance.md",
    "migration": "./docs/migration.md",
    "browserSupport": "./docs/browser-support.md",
    "deprecationPolicy": "./docs/deprecation-policy.md",
    "checklist": "./docs/release-checklist.md",
    "checksums": "./dist/interface-framework.checksums.json",
    "sha256sums": "./dist/SHA256SUMS",
    "provenance": "./release/provenance.json"
  },
  "sideEffects": [
    "*.css",
    "dist/*.css",
    "src/styles/*.css",
    "src/tokens/*.css"
  ],
  "files": [
    "dist",
    "src",
    "starters",
    "examples",
    "docs",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/interface-framework.esm.js",
      "default": "./dist/interface-framework.esm.js",
      "style": "./dist/interface-framework.css"
    },
    "./css": "./dist/interface-framework.css",
    "./css/min": "./dist/interface-framework.min.css",
    "./js": {
      "import": "./dist/interface-framework.esm.js",
      "browser": "./dist/interface-framework.js",
      "default": "./dist/interface-framework.js"
    },
    "./js/min": "./dist/interface-framework.min.js",
    "./js/esm": "./dist/interface-framework.esm.js",
    "./js/esm/min": "./dist/interface-framework.esm.min.js",
    "./tokens": "./src/tokens/index.css",
    "./component-manifest": "./docs/component-manifest.json",
    "./recipes": "./docs/recipes.md",
    "./event-catalog": "./docs/event-catalog.md",
    "./agentic-ergonomics": "./docs/agentic-ergonomics.md",
    "./agent-handoff": "./docs/agent-handoff.md",
    "./mvp-route-contracts": "./docs/mvp-route-contracts.md",
    "./route-component-map": "./docs/route-component-map.md",
    "./adapter-fixture-contracts": "./docs/adapter-fixture-contracts.md",
    "./mvp-acceptance-checklist": "./docs/mvp-acceptance-checklist.md",
    "./public-site-handoff": "./docs/public-site-handoff.md",
    "./github-shipping-work-items": "./docs/github-shipping-work-items.md",
    "./starters": "./starters/README.md",
    "./starters/policy-plain-html": "./starters/policy-plain-html/README.md",
    "./starters/policy-vite": "./starters/policy-vite/README.md",
    "./starters/adamboas-plain-html": "./starters/adamboas-plain-html/README.md",
    "./starters/adamboas-vite": "./starters/adamboas-vite/README.md",
    "./graph-diagram-production-path": "./docs/graph-diagram-production-path.md",
    "./document-intelligence-production-path": "./docs/document-intelligence-production-path.md",
    "./package-handoff": "./docs/package-handoff.md",
    "./performance-budgets": "./docs/performance-budgets.md",
    "./qa-baseline": "./docs/qa-baseline.md",
    "./theme-contrast-report": "./docs/theme-contrast-report.md",
    "./theme-contrast-report/json": "./docs/theme-contrast-report.json",
    "./forced-colors": "./docs/forced-colors.md",
    "./release-governance": "./docs/release-governance.md",
    "./migration": "./docs/migration.md",
    "./browser-support": "./docs/browser-support.md",
    "./deprecation-policy": "./docs/deprecation-policy.md",
    "./release-checklist": "./docs/release-checklist.md",
    "./checksums": "./dist/interface-framework.checksums.json",
    "./sha256sums": "./dist/SHA256SUMS",
    "./dist/interface-framework.css": "./dist/interface-framework.css",
    "./dist/interface-framework.min.css": "./dist/interface-framework.min.css",
    "./dist/interface-framework.js": "./dist/interface-framework.js",
    "./dist/interface-framework.min.js": "./dist/interface-framework.min.js",
    "./dist/interface-framework.esm.js": "./dist/interface-framework.esm.js",
    "./dist/interface-framework.esm.min.js": "./dist/interface-framework.esm.min.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "accessibility": "node scripts/accessibility-tests.mjs",
    "a11y": "node scripts/accessibility-tests.mjs",
    "build": "node scripts/build.mjs",
    "behavior": "node scripts/behavior-tests.mjs",
    "check": "node scripts/validate.mjs",
    "checksums": "node scripts/checksums.mjs",
    "dev": "node scripts/dev-server.mjs",
    "playwright:install": "playwright install",
    "preview": "node scripts/dev-server.mjs",
    "release:provenance": "node scripts/release-provenance.mjs",
    "release:provenance:check": "node scripts/release-provenance.mjs --check",
    "release:smoke": "node scripts/release-smoke.mjs",
    "release:verify": "node scripts/build.mjs && node scripts/checksums.mjs --check && node scripts/release-provenance.mjs --check && node scripts/validate.mjs",
    "test:a11y:browser": "playwright test tests/playwright/a11y.spec.mjs",
    "test:browser": "playwright test",
    "test:contracts": "node scripts/component-contract-tests.mjs",
    "test:diagrams": "node scripts/diagram-component-tests.mjs",
    "test:visual": "playwright test tests/playwright/visual.spec.mjs",
    "test": "node scripts/validate.mjs",
    "theme:compile": "node scripts/theme-compiler.mjs",
    "validate": "node scripts/validate.mjs"
  },
  "keywords": [
    "css-framework",
    "design-tokens",
    "control-surface",
    "enterprise-ui",
    "analytics-ui",
    "vanilla-js",
    "vite"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
